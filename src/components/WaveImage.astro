---
interface Props {
    src: string;
    alt?: string;
}

const { src, alt = '' } = Astro.props;
---

<canvas class="wave-image" data-src={src} role="img" aria-label={alt}></canvas>

<script>
    // Port of scripts/line.py: render an image as horizontal wavy lines whose
    // amplitude/frequency grow with how far each pixel's tone is from the
    // background. The waves ripple while the mouse is over the canvas.

    const PROC_WIDTH = 200; // detail-map resolution (px in processing space)
    const DISPLAY_HEIGHT = 500; // rendered height on the page (px)
    const LINE_SPACING = 3; // vertical gap between lines, processing px
    const AMPLITUDE = 2; // max vertical oscillation, processing px
    const FREQUENCY = 2; // base phase step, radians per px
    const LINE_WIDTH = 0.5; // stroke width in processing px
    const COLOR = '#2e2a24';
    const BACKGROUND = '#f5f1e8';

    // Rope physics (1D damped wave equation per line).
    const C2 = 0.5; // wave-propagation speed^2 (keep < 0.5 for stability)
    const DAMP = 0.992; // velocity damping per step (energy bleed-off)
    const REST = 0.01; // pull each point back toward its resting shape
    const PLUCK_SIGMA = 5; // width of the disturbance injected, processing px
    const PLUCK_GAIN = 0.05; // how hard the cursor plucks per unit of speed
    const PLUCK_MAX = 1; // clamp on a single pluck impulse
    const REST_EPS = 1e-1; // below this total energy a line is considered still

    function parseColor(hex: string) {
        const v = hex.replace('#', '');
        return {
            r: parseInt(v.slice(0, 2), 16),
            g: parseInt(v.slice(2, 4), 16),
            b: parseInt(v.slice(4, 6), 16),
        };
    }

    const lum = (r: number, g: number, b: number) =>
        0.299 * r + 0.587 * g + 0.114 * b;

    function setup(canvas: HTMLCanvasElement) {
        const img = new Image();
        img.onload = () => render(canvas, img);
        img.src = canvas.dataset.src!;
    }

    function render(canvas: HTMLCanvasElement, img: HTMLImageElement) {
        const ratio = img.height / img.width;
        const pw = PROC_WIDTH;
        const ph = Math.round(pw * ratio);

        // Offscreen draw to sample pixels.
        const off = document.createElement('canvas');
        off.width = pw;
        off.height = ph;
        const octx = off.getContext('2d')!;
        octx.drawImage(img, 0, 0, pw, ph);
        const data = octx.getImageData(0, 0, pw, ph).data;

        // Per-pixel distance from the background tone, 0..1.
        const bg = parseColor(BACKGROUND);
        const bgLum = lum(bg.r, bg.g, bg.b);
        const norm = Math.max(bgLum, 255 - bgLum);
        const detail = new Float32Array(pw * ph);
        for (let i = 0; i < pw * ph; i++) {
            const d =
                Math.abs(lum(data[i * 4], data[i * 4 + 1], data[i * 4 + 2]) - bgLum) /
                norm;
            detail[i] = Math.min(1, Math.max(0, d));
        }

        // Display sizing: scale processing space up to DISPLAY_HEIGHT, honoring
        // device pixel ratio for crisp lines.
        const scale = DISPLAY_HEIGHT / ph;
        const dpr = window.devicePixelRatio || 1;
        const dispW = pw * scale;
        const dispH = ph * scale;
        canvas.style.width = `${dispW}px`;
        canvas.style.height = `${dispH}px`;
        canvas.width = Math.round(dispW * dpr);
        canvas.height = Math.round(dispH * dpr);
        const ctx = canvas.getContext('2d')!;
        ctx.scale(dpr * scale, dpr * scale); // draw in processing coordinates

        // Build each line as an independent rope: a resting shape (the static
        // wavy render) plus dynamic displacement/velocity arrays.
        type Rope = {
            y: number;
            base: Float32Array; // resting offset from y, per column
            disp: Float32Array; // current dynamic displacement, per column
            vel: Float32Array; // displacement velocity, per column
        };
        const ropes: Rope[] = [];
        let lineIndex = 0;
        for (let y = LINE_SPACING / 2; y < ph; y += LINE_SPACING) {
            const row = Math.min(Math.floor(y), ph - 1) * pw;
            const base = new Float32Array(pw);
            let phase = lineIndex * 0.7;
            for (let x = 0; x < pw; x++) {
                const d = detail[row + x];
                base[x] = AMPLITUDE * d * Math.sin(phase);
                phase += FREQUENCY * (0.2 + d);
            }
            ropes.push({
                y,
                base,
                disp: new Float32Array(pw),
                vel: new Float32Array(pw),
            });
            lineIndex++;
        }

        let running = false;
        let prevX = 0;
        let prevY = 0;
        let havePrev = false;

        // Pluck a rope at column `col`, injecting a localized velocity impulse
        // (a small Gaussian bump) so the disturbance propagates and rings.
        function pluck(rope: Rope, col: number, impulse: number) {
            const lo = Math.max(1, Math.floor(col - PLUCK_SIGMA * 3));
            const hi = Math.min(pw - 2, Math.ceil(col + PLUCK_SIGMA * 3));
            const inv2s2 = 1 / (2 * PLUCK_SIGMA * PLUCK_SIGMA);
            for (let x = lo; x <= hi; x++) {
                const dx = x - col;
                rope.vel[x] += impulse * Math.exp(-dx * dx * inv2s2);
            }
        }

        canvas.addEventListener('mousemove', (e) => {
            const rect = canvas.getBoundingClientRect();
            const mx = (e.clientX - rect.left) / scale;
            const my = (e.clientY - rect.top) / scale;

            if (havePrev) {
                const velY = my - prevY;
                const col = Math.round(mx);
                if (col >= 1 && col <= pw - 2) {
                    // Pluck every rope the cursor swept across this frame, so a
                    // fast move strums through the whole stack.
                    const top = Math.min(prevY, my);
                    const bot = Math.max(prevY, my);
                    for (const rope of ropes) {
                        const ry = rope.y + rope.base[col] + rope.disp[col];
                        if (ry >= top - 1 && ry <= bot + 1) {
                            let imp = velY * PLUCK_GAIN;
                            if (imp > PLUCK_MAX) imp = PLUCK_MAX;
                            else if (imp < -PLUCK_MAX) imp = -PLUCK_MAX;
                            // Ensure even a slow graze imparts some tension.
                            if (Math.abs(imp) < 0.5) imp = imp >= 0 ? 0.5 : -0.5;
                            pluck(rope, col, imp);
                        }
                    }
                }
            }
            prevX = mx;
            prevY = my;
            havePrev = true;
            if (!running) loop();
        });
        canvas.addEventListener('mouseleave', () => {
            havePrev = false;
        });

        function step() {
            let active = false;
            for (const rope of ropes) {
                const { disp, vel } = rope;
                // Damped wave equation along the rope.
                for (let x = 1; x < pw - 1; x++) {
                    const lap = disp[x - 1] + disp[x + 1] - 2 * disp[x];
                    vel[x] = (vel[x] + C2 * lap - REST * disp[x]) * DAMP;
                }
                let energy = 0;
                for (let x = 1; x < pw - 1; x++) {
                    disp[x] += vel[x];
                    energy += vel[x] * vel[x] + disp[x] * disp[x];
                }
                if (energy > REST_EPS) active = true;
                else {
                    disp.fill(0);
                    vel.fill(0);
                }
            }
            return active;
        }

        function drawFrame() {
            ctx.clearRect(0, 0, pw, ph);
            ctx.strokeStyle = COLOR;
            ctx.lineWidth = LINE_WIDTH;
            ctx.lineJoin = 'round';
            ctx.lineCap = 'round';

            for (const rope of ropes) {
                const { y, base, disp } = rope;
                ctx.beginPath();
                for (let x = 0; x < pw; x++) {
                    const py = y + base[x] + disp[x];
                    if (x === 0) ctx.moveTo(x, py);
                    else ctx.lineTo(x, py);
                }
                ctx.stroke();
            }
        }

        function loop() {
            running = true;
            const active = step();
            drawFrame();
            // Keep simulating while the cursor is engaged or ropes still ring.
            if (active || havePrev) {
                requestAnimationFrame(loop);
            } else {
                running = false;
            }
        }

        drawFrame(); // initial static render
    }

    document
        .querySelectorAll<HTMLCanvasElement>('canvas.wave-image')
        .forEach(setup);
</script>
